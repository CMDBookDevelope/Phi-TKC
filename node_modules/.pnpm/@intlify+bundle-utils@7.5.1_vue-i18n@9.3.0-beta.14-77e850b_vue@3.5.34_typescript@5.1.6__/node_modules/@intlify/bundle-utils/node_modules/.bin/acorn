            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/user/Phi-TK/Phi-TKC/node_modules/.pnpm/acorn@8.16.0/node_modules/acorn/node_modules:/home/user/Phi-TK/Phi-TKC/node_modules/.pnpm/acorn@8.16.0/node_modules:/home/user/Phi-TK/Phi-TKC/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/user/Phi-TK/Phi-TKC/node_modules/.pnpm/acorn@8.16.0/node_modules/acorn/node_modules:/home/user/Phi-TK/Phi-TKC/node_modules/.pnpm/acorn@8.16.0/node_modules:/home/user/Phi-TK/Phi-TKC/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../../../acorn/bin/acorn" "$@"
else
  exec node  "$basedir/../../../../acorn/bin/acorn" "$@"
fi
