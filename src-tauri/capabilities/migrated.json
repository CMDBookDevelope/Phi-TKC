{
  "identifier": "migrated",
  "description": "permissions that were migrated from v1",
  "local": true,
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "https://api.yppp.net/**"
        }
      ]
    },
    {
      "identifier": "fs:allow-read-file",
      "allow": [
        "$RESOURCE/*",
        "$APP/*",
        "$USER/*",
        "$APPDATA/**",
        "$DOCUMENT/*",
        "$DOWNLOAD/*",
        "$PICTURE/**/*",
        "$DESKTOP/**/*",
        "$HOME/**/*",
        "**/*.jpg",
        "**/*.png",
        "**/*.webp"
      ]
    },
    {
      "identifier": "fs:allow-write-file",
      "allow": [
        "$APPDATA/**"
      ]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [
        "$APPDATA/**"
      ]
    },
    "shell:allow-open",
    "dialog:allow-open",
    "dialog:allow-message",
    "os:allow-platform",
    "os:allow-version",
    "os:allow-os-type",
    "os:allow-family",
    "os:allow-arch",
    "os:allow-exe-extension",
    "os:allow-locale",
    "os:allow-hostname",
    "fs:default",
    "os:default",
    "shell:default",
    "dialog:default"
  ]
}